# ============================================================
# INSTAGRAM AUTOMATION - 3W ENTRETENIMENTO
# Copie para .env e preencha
# ============================================================

# Contas Instagram
INSTAGRAM_MAIN=3worlds_entertainment
INSTAGRAM_ESPORTS=3wesports
INSTAGRAM_COMICS=3wcomics_

# Posts por conta (máximo recomendado: 30)
MAX_POSTS=30

# ============================================================
# COOKIE DE SESSÃO — necessário para buscar mais de 12 posts
# ============================================================
# Como obter (leva ~1 minuto):
#   1. Abra https://www.instagram.com no Chrome ou Edge
#   2. Faça login com QUALQUER conta Instagram (pode ser conta pessoal)
#   3. Pressione F12 → aba "Application" → "Cookies" → instagram.com
#   4. Copie os valores de "sessionid" e "csrftoken"
#
# IMPORTANTE: o cookie fica APENAS neste arquivo .env no seu computador
# (e nos GitHub Secrets). O site nunca vê essas credenciais.
# Expira em ~90 dias — renove copiando os cookies novamente.

INSTAGRAM_SESSION_ID=
INSTAGRAM_CSRF_TOKEN=
